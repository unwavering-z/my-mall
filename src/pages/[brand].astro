---
// src/pages/[brand].astro
import productData from '../data/products.json';
import '../styles/mall.css';
const { festival } = productData;
// 1. 告诉 Astro 根据 JSON 数据生成哪些路径
export async function getStaticPaths() {
  const { brands } = productData;
  // 排除首页(index)，为其他品牌生成独立页面
  return brands
    .filter(brand => brand.slug !== 'index')
    .map(brand => ({
      params: { brand: brand.slug }, // URL 里的名字，如 /yuexiang
      props: { brandId: brand.id }   // 传给页面的品牌 ID
    }));
}

// 2. 获取当前页面的参数
const { brand } = Astro.params;
const { brandId } = Astro.props;

// 3. 筛选当前品牌和产品数据
const currentBrand = productData.brands.find(b => b.id === brandId);
const displayProducts = productData.items.filter(item => item.brandId === brandId);
---

<html lang="zh-cn">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{currentBrand.name} - 2026端午团购</title>
<script is:inline>
  // 1. 监听点击，记录位置
  document.addEventListener('click', (e) => {
    const link = e.target.closest('.product-link');
    if (link) {
      sessionStorage.setItem('scroll-pos-' + window.location.pathname, window.scrollY);
    }
  });

  // 2. 返回时恢复位置
  window.addEventListener('load', () => {
    const savedPos = sessionStorage.getItem('scroll-pos-' + window.location.pathname);
    if (savedPos !== null) {
      // 关键：给微信一点点缓冲时间（100ms），等它把 480px 布局渲染好
      setTimeout(() => {
        window.scrollTo({
          top: parseInt(savedPos, 10),
          behavior: 'instant' // 立即跳转，不要平滑滚动
        });
        sessionStorage.removeItem('scroll-pos-' + window.location.pathname);
      }, 100); 
    }
  });
</script>
</head>
<body>
    <div class="festival-banner" id="countdown-banner">
  <span class="festival-name">🏮 {festival.name}</span>
  <span class="countdown-text">
    距节日还有 <strong id="days-count">--</strong> 天
  </span>
</div>

<script define:vars={{ targetDate: festival.targetDate }}>
  function updateCountdown() {
    const target = new Date(targetDate).getTime();
    const now = new Date().getTime();
    const gap = target - now;
    
    const d = Math.floor(gap / (1000 * 60 * 60 * 24));
    document.getElementById('days-count').innerText = d > 0 ? d : 0;
  }
  updateCountdown();
</script>

<style define:vars={{ themeColor: festival.themeColor }}>
  /* --- 顶部公告条样式 --- */
  .festival-banner {
    background: var(--themeColor);
    color: white;
    padding: 8px 15px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 13px;
    position: sticky;
    top: 0;
    z-index: 1001;
  }
  .festival-name { font-weight: bold; }
  #days-count { font-size: 16px; color: #ffeb3b; margin: 0 2px; }

  /* --- 侧边栏高亮精准修复 --- */
  
  /* 1. 改变左侧小窄条的颜色 (假设它是通过 ::before 或 border 实现的) */
  :global(.side-menu a.active::before) {
    background-color: var(--themeColor) !important;
  }
  
  /* 2. 如果你的窄条是用左边框 border-left 实现的，用这一行 */
  :global(.side-menu a.active) {
    border-left-color: var(--themeColor) !important;
    background-color: transparent !important; /* 去掉大面积背景色 */
    color: var(--themeColor) !important;       /* 文字也变成主题色，不选橙色 */
    font-weight: bold;
  }
</style>
    <header class="hero-banner">
        <img src="/hero-banner.png" alt="马年大吉" />
    </header>

    <main class="mall-container">
        <nav class="side-menu">
            {productData.brands.map((b) => (
                <a href={b.slug === 'index' ? '/' : `/${b.slug}`} 
                   class={b.id === brandId ? "active" : ""}>
                    {b.name}
                </a>
            ))}
        </nav>

        <section class="product-grid">
            <div class="grid">
                {displayProducts.map((product) => (
                    <a href={`/details/${product.detail}`} class="product-link">
                        <div class="product-card">
                            <img src={product.image} alt={product.name} />
                            <div class="info">
                                <h3>{product.name}</h3>
                                <p class="price">{product.price}</p>
                            </div>
                        </div>
                    </a>
                ))}
            </div>
        </section>
    </main>
</body>
</html>
